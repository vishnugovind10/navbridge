{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vishnugovind10/navbridge/docs/report_schema_v1.json",
  "title": "NavBridge Divergence Report v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "fund_id",
    "report_window_start",
    "report_window_end",
    "input_record_counts",
    "monitor_parameters",
    "config_snapshot",
    "policy_pack",
    "total_observations",
    "total_breaks",
    "material_breaks",
    "critical_breaks",
    "mean_divergence_bps",
    "max_divergence_bps",
    "break_type_distribution",
    "policy_compliance",
    "events",
    "recommended_tolerance_bps",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "const": "navbridge.report.v1" },
    "run_id": { "type": ["string", "null"] },
    "fund_id": { "type": "string" },
    "report_window_start": { "type": "string", "format": "date-time" },
    "report_window_end": { "type": "string", "format": "date-time" },
    "input_record_counts": {
      "type": "object",
      "required": ["oracle", "administrator", "aligned"],
      "properties": {
        "oracle": { "type": "integer", "minimum": 0 },
        "administrator": { "type": "integer", "minimum": 0 },
        "aligned": { "type": "integer", "minimum": 0 }
      }
    },
    "monitor_parameters": { "type": "object" },
    "config_snapshot": { "type": "object" },
    "policy_pack": { "type": ["object", "null"] },
    "total_observations": { "type": "integer", "minimum": 0 },
    "total_breaks": { "type": "integer", "minimum": 0 },
    "material_breaks": { "type": "integer", "minimum": 0 },
    "critical_breaks": { "type": "integer", "minimum": 0 },
    "mean_divergence_bps": { "type": "number" },
    "max_divergence_bps": { "type": "number" },
    "break_type_distribution": { "type": "object" },
    "policy_compliance": { "type": "boolean" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fund_id",
          "oracle_record",
          "administrator_record",
          "divergence_bps",
          "divergence_direction",
          "break_type",
          "severity",
          "classification_confidence",
          "classification_rule_id",
          "classification_ruleset_version",
          "classification_evidence",
          "notes"
        ]
      }
    },
    "recommended_tolerance_bps": { "type": ["number", "null"] },
    "generated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
